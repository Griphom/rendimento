@page "/conferencia-descontos"

<PageTitle>Conferencia de Descontos</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenCard>
        <RadzenText Text="Acompanhamento Detalhado de Descontos" TextStyle="TextStyle.H5" TagName="TagName.H1" />
        <RadzenText Text="Sempre retorna os 100 primeiros registros do mes selecionado." TextStyle="TextStyle.Body2" />
    </RadzenCard>

    <RadzenCard>
        <RadzenRow Gap="1rem" RowGap="1rem">
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenLabel Text="Cedente" Component="FiltroCedente" />
                <RadzenDropDown Name="FiltroCedente" TValue="long?" Data="@cedentes" TextProperty="Nome" ValueProperty="IdCedente" @bind-Value="idCedenteSelecionado" Change="@(async _ => await OnCedenteChanged())" Style="width: 100%;" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenLabel Text="Lote" Component="FiltroLote" />
                <RadzenDropDown Name="FiltroLote" TValue="long?" Data="@lotes" TextProperty="IdentificadorExt" ValueProperty="IdLote" @bind-Value="idLoteSelecionado" AllowClear="true" Style="width: 100%;" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenLabel Text="Mes de Referencia" Component="FiltroMes" />
                <RadzenDatePicker Name="FiltroMes" TValue="DateTime" @bind-Value="mesSelecionado" DateFormat="yyyy-MM" Style="width: 100%;" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" class="rz-mt-4">
            <RadzenButton Icon="search" Text="Buscar" Click="@Buscar" />
        </RadzenStack>
    </RadzenCard>

    <RadzenCard>
        <RadzenText Text="@($"Resultados: {resultados.Count} (TOP 100)")" TextStyle="TextStyle.Body2" />
        <RadzenDataGrid TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Data="@resultados" AllowPaging="true" PageSize="20" AllowSorting="true" EmptyText="Nenhum registro encontrado para os filtros selecionados.">
            <Columns>
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="NomeCedente" Title="Cedente" Width="180px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="NomeLote" Title="Lote" Width="160px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="NomeCliente" Title="Cliente" Width="220px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="IdOperacao" Title="Operacao" Width="100px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="NumeroParcela" Title="Parcela" Width="90px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="DataPrevistaDesconto" Title="Data Prevista" Width="120px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="DataDescontoReal" Title="Data Real" Width="120px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="ValorPrevistoDesconto" Title="Valor Previsto" Width="130px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="ValorDescontado" Title="Valor Descontado" Width="140px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="DiferencaValorDesconto" Title="Diferenca" Width="120px" />
                <RadzenDataGridColumn TItem="Servicing.Services.ConferenciaDescontoDetalhadoItem" Property="StatusConferencia" Title="Status" Width="280px" />
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
</RadzenStack>
