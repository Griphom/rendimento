@page "/enderecos-cliente"

<PageTitle>Enderecos do Cliente</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenCard>
        <RadzenText Text="Cadastro de Enderecos do Cliente" TextStyle="TextStyle.H5" TagName="TagName.H1" />
    </RadzenCard>

    <RadzenCard>
        <RadzenTemplateForm TItem="Servicing.Models.sql_rendimento_consignado.EnderecosCliente" Data="@editModel" Submit="@SaveEndereco">
            <RadzenRow Gap="1rem" RowGap="1rem">
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenLabel Text="Id Cliente" Component="IdCliente" />
                    <RadzenNumeric Name="IdCliente" TValue="long" @bind-Value="editModel.IdCliente" Style="width: 100%;" />
                    <RadzenRequiredValidator Component="IdCliente" Text="IdCliente e obrigatorio" Popup="true" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenLabel Text="Apelido" Component="Apelido" />
                    <RadzenTextBox Name="Apelido" @bind-Value="editModel.Apelido" Style="width: 100%;" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Logradouro" Component="Logradouro" />
                    <RadzenTextBox Name="Logradouro" @bind-Value="editModel.Logradouro" Style="width: 100%;" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenLabel Text="Numero" Component="Numero" />
                    <RadzenTextBox Name="Numero" @bind-Value="editModel.Numero" Style="width: 100%;" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenLabel Text="Complemento" Component="Complemento" />
                    <RadzenTextBox Name="Complemento" @bind-Value="editModel.Complemento" Style="width: 100%;" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenLabel Text="Bairro" Component="Bairro" />
                    <RadzenTextBox Name="Bairro" @bind-Value="editModel.Bairro" Style="width: 100%;" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenLabel Text="Municipio" Component="Municipio" />
                    <RadzenTextBox Name="Municipio" @bind-Value="editModel.Municipio" Style="width: 100%;" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenLabel Text="UF" Component="UF" />
                    <RadzenTextBox Name="UF" @bind-Value="editModel.UF" Style="width: 100%;" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenLabel Text="Pais" Component="Pais" />
                    <RadzenTextBox Name="Pais" @bind-Value="editModel.Pais" Style="width: 100%;" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenCheckBox Name="Comercial" TValue="bool?" @bind-Value="editModel.Comercial" />
                    <RadzenLabel Text="Comercial" Component="Comercial" class="rz-ml-2" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenCheckBox Name="Residencial" TValue="bool?" @bind-Value="editModel.Residencial" />
                    <RadzenLabel Text="Residencial" Component="Residencial" class="rz-ml-2" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenCheckBox Name="Principal" TValue="bool?" @bind-Value="editModel.Principal" />
                    <RadzenLabel Text="Principal" Component="Principal" class="rz-ml-2" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" class="rz-mt-4">
                <RadzenButton ButtonType="ButtonType.Submit" Icon="save" Text="Salvar" />
                <RadzenButton ButtonStyle="ButtonStyle.Light" Icon="add" Text="Novo" Click="@PrepareNewEndereco" />
                @if (isEditing)
                {
                    <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="close" Text="Cancelar Edicao" Click="@PrepareNewEndereco" />
                }
            </RadzenStack>
        </RadzenTemplateForm>
    </RadzenCard>

    <RadzenCard>
        <RadzenDataGrid TItem="Servicing.Models.sql_rendimento_consignado.EnderecosCliente" Data="@enderecos" AllowSorting="true" AllowPaging="true" PageSize="10" EmptyText="Nenhum endereco encontrado.">
            <Columns>
                <RadzenDataGridColumn TItem="Servicing.Models.sql_rendimento_consignado.EnderecosCliente" Property="IdEndereco" Title="ID" Width="100px" />
                <RadzenDataGridColumn TItem="Servicing.Models.sql_rendimento_consignado.EnderecosCliente" Property="IdCliente" Title="Cliente" Width="120px" />
                <RadzenDataGridColumn TItem="Servicing.Models.sql_rendimento_consignado.EnderecosCliente" Property="Logradouro" Title="Logradouro" />
                <RadzenDataGridColumn TItem="Servicing.Models.sql_rendimento_consignado.EnderecosCliente" Property="Municipio" Title="Municipio" />
                <RadzenDataGridColumn TItem="Servicing.Models.sql_rendimento_consignado.EnderecosCliente" Property="UF" Title="UF" Width="90px" />
                <RadzenDataGridColumn TItem="Servicing.Models.sql_rendimento_consignado.EnderecosCliente" Title="Acoes" Width="170px" Sortable="false" Filterable="false" TextAlign="TextAlign.Center">
                    <Template Context="item">
                        <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Flat" Click="@(args => BeginEdit(item))" class="rz-mr-2" />
                        <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Danger" Click="@(args => DeleteEndereco(item))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
</RadzenStack>
